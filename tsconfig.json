{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "types": ["node"],
    "paths": {
      "@watermart/core": ["./packages/core/src/index.ts"],
      "@watermart/core/*": ["./packages/core/src/*"],
      "@watermart/product": ["./packages/modules/product/src/index.ts"],
      "@watermart/product/*": ["./packages/modules/product/src/*"],
      "@watermart/catalog": ["./packages/modules/catalog/src/index.ts"],
      "@watermart/catalog/*": ["./packages/modules/catalog/src/*"],
      "@watermart/cart": ["./packages/modules/cart/src/index.ts"],
      "@watermart/cart/*": ["./packages/modules/cart/src/*"],
      "@watermart/inventory": ["./packages/modules/inventory/src/index.ts"],
      "@watermart/inventory/*": ["./packages/modules/inventory/src/*"],
      "@watermart/pricing": ["./packages/modules/pricing/src/index.ts"],
      "@watermart/pricing/*": ["./packages/modules/pricing/src/*"],
      "@watermart/payment": ["./packages/modules/payment/src/index.ts"],
      "@watermart/payment/*": ["./packages/modules/payment/src/*"],
      "@watermart/order": ["./packages/modules/order/src/index.ts"],
      "@watermart/order/*": ["./packages/modules/order/src/*"],
      "@watermart/customer": ["./packages/modules/customer/src/index.ts"],
      "@watermart/customer/*": ["./packages/modules/customer/src/*"],
      "@watermart/shipping": ["./packages/modules/shipping/src/index.ts"],
      "@watermart/shipping/*": ["./packages/modules/shipping/src/*"],
      "@watermart/affiliate": ["./packages/modules/affiliate/src/index.ts"],
      "@watermart/affiliate/*": ["./packages/modules/affiliate/src/*"],
      "@watermart/marketing": ["./packages/modules/marketing/src/index.ts"],
      "@watermart/marketing/*": ["./packages/modules/marketing/src/*"],
      "@watermart/content": ["./packages/modules/content/src/index.ts"],
      "@watermart/content/*": ["./packages/modules/content/src/*"],
      "@watermart/notification": ["./packages/modules/notification/src/index.ts"],
      "@watermart/notification/*": ["./packages/modules/notification/src/*"],
      "@watermart/support": ["./packages/modules/support/src/index.ts"],
      "@watermart/support/*": ["./packages/modules/support/src/*"],
      "@watermart/analytics": ["./packages/modules/analytics/src/index.ts"],
      "@watermart/analytics/*": ["./packages/modules/analytics/src/*"],
      "@watermart/compliance": ["./packages/modules/compliance/src/index.ts"],
      "@watermart/compliance/*": ["./packages/modules/compliance/src/*"]
    }
  },
  "include": ["apps/**/*.ts", "apps/**/*.tsx", "packages/**/*.ts", "packages/**/*.tsx", "tooling/**/*.ts"],
  "exclude": ["node_modules", ".next", "dist", ".turbo", "**/*.test.ts", "**/*.spec.ts"]
}
