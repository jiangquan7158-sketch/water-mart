# Environment
NODE_ENV=development

# Database
DATABASE_URL="postgresql://watermart:watermart@localhost:5432/watermart?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Next.js
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_ADMIN_URL="http://localhost:3001"

# Meilisearch
NEXT_PUBLIC_MEILISEARCH_URL="http://localhost:7700"
MEILISEARCH_MASTER_KEY="change-me-in-production"

# Stripe
STRIPE_SECRET_KEY="sk_test_xxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# PayPal
PAYPAL_CLIENT_ID="xxx"
PAYPAL_CLIENT_SECRET="xxx"

# Anthropic (Claude API)
CLAUDE_API_KEY="sk-ant-xxx"

# S3 / Cloudflare R2
S3_ENDPOINT="https://xxx.r2.cloudflarestorage.com"
S3_ACCESS_KEY="xxx"
S3_SECRET_KEY="xxx"
S3_BUCKET="watermart"
S3_REGION="auto"
S3_PUBLIC_URL="https://cdn.yourdomain.com"

# SMTP
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="noreply@yourdomain.com"
SMTP_PASS="xxx"
SMTP_FROM="WaterMart <noreply@yourdomain.com>"

# JWT / Auth
AUTH_SECRET="change-me-to-a-random-64-char-string"
AUTH_GOOGLE_ID="xxx"
AUTH_GOOGLE_SECRET="xxx"

# Scraper
SCRAPER_PROXY_URL=""       # Optional: Bright Data proxy
SCRAPER_CONCURRENCY="3"    # Max parallel scraping workers
SCRAPER_TIMEOUT="30000"    # Per-page timeout in ms

# Feature Flags
FEATURE_IMAGE_SEARCH=true
FEATURE_AI_OPTIMIZE=true
FEATURE_AFFILIATE=true
