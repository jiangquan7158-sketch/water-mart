{
  "name": "@watermart/core",
  "version": "0.1.0",
  "private": true,
  "description": "Core infrastructure package for WaterMart global e-commerce platform",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist .turbo node_modules",
    "lint": "prettier --check \"src/**/*.ts\"",
    "lint:fix": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate --schema=src/database/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=src/database/schema.prisma",
    "db:push": "prisma db push --schema=src/database/schema.prisma",
    "db:seed": "tsx src/database/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.800.0",
    "@aws-sdk/s3-request-presigner": "^3.800.0",
    "@prisma/client": "^6.6.0",
    "date-fns": "^4.1.0",
    "ioredis": "^5.6.0",
    "uuid": "^11.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/uuid": "^10.0.0",
    "prisma": "^6.19.3",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  },
  "prisma": {
    "schema": "src/database/schema.prisma"
  }
}
